# Backend API
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# Must match backend/.env JWT_SECRET — used by Next.js middleware
# (frontend/middleware.ts) to verify the auth cookie before allowing
# access to protected routes like /admin, /checkout, /orders, /cart.
JWT_SECRET=replace_with_same_backend_jwt_secret

# Stripe (PUBLIC key only — safe for browser)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_public_key

# Sentry (optional)
NEXT_PUBLIC_SENTRY_DSN=
